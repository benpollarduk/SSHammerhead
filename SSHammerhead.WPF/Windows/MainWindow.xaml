<Window x:Class="SSHammerhead.WPF.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:NetAF.Targets.WPF.Controls;assembly=NetAF.WPF"
        xmlns:layouts="clr-namespace:NetAF.Targets.WPF.InputLayouts;assembly=NetAF.WPF"
        xmlns:local="clr-namespace:SSHammerhead.WPF.Windows"
        xmlns:localControls="clr-namespace:SSHammerhead.WPF.Controls"
        xmlns:top="clr-namespace:SSHammerhead.WPF"
        xmlns:effects="clr-namespace:LoFiEffects.WPF.Effects;assembly=LoFiEffects.WPF"
        xmlns:converters="clr-namespace:SSHammerhead.WPF.Converters"
        mc:Ignorable="d"
        Title="Trouble Aboard the SS Hammerhead" Height="850" Width="1000" WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/NetAF.WPF;component/Targets/WPF/Styles/Dark.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <effects:CrtEffect x:Key="CrtEffect" Intensity="{Binding Source={x:Static top:App.Settings}, Path=CrtIntensity, Mode=OneWay}" CurvatureIntensity="{Binding Source={x:Static top:App.Settings}, Path=CrtCurvatureIntensity, Mode=OneWay}" Brightness="{Binding Source={x:Static top:App.Settings}, Path=CrtBrightness, Mode=OneWay}" IncludeScanlines="{Binding Source={x:Static top:App.Settings}, Path=UseCrtScanlines, Mode=OneWay}"/>
            <RoutedUICommand x:Key="OpenSettingsCommand" Text="Settings"/>
            <RoutedUICommand x:Key="OpenPersistenceCommand" Text="Save/Load"/>
            <RoutedUICommand x:Key="OpenNoteManagerCommand" Text="Notes"/>
            <RoutedUICommand x:Key="FullScreenCommand" Text="Fullscreen"/>
            <CornerRadius x:Key="WindowCornerRadius">3</CornerRadius>
            <converters:ObjectNotNullToBooleanConverter x:Key="ObjectNotNullToBooleanConverter"/>
            <converters:ObjectNullToBooleanConverter x:Key="ObjectNullToBooleanConverter"/>
            <converters:BooleanToVisibilityCollapsedConverter x:Key="BooleanToVisibilityCollapsedConverter"/>
            <converters:BooleanToVisibilityHiddenConverter x:Key="BooleanToVisibilityHiddenConverter"/>
            <converters:IntToModifiedFlowDocumentThemeConverter x:Key="IntToModifiedFlowDocumentThemeConverter"/>
        </ResourceDictionary>
    </Window.Resources>
    <Window.CommandBindings>
        <CommandBinding x:Name="OpenSettingsCommandBinding" Command="{StaticResource OpenSettingsCommand}" Executed="OpenSettingsCommandBinding_Executed"/>
        <CommandBinding x:Name="OpenPersistenceCommandBinding" Command="{StaticResource OpenPersistenceCommand}" Executed="OpenPersistenceCommandBinding_Executed"/>
        <CommandBinding x:Name="OpenNoteManagerCommandBinding" Command="{StaticResource OpenNoteManagerCommand}" Executed="OpenNoteManagerCommandBinding_Executed"/>
        <CommandBinding x:Name="FullScreenCommandBinding" Command="{StaticResource FullScreenCommand}" Executed="FullScreenCommandBinding_Executed"/>
    </Window.CommandBindings>
    <Window.InputBindings>
        <KeyBinding Command="{StaticResource OpenSettingsCommand}" Gesture="Ctrl+R"/>
        <KeyBinding Command="{StaticResource OpenPersistenceCommand}" Gesture="Ctrl+O"/>
        <KeyBinding Command="{StaticResource FullScreenCommand}" Gesture="F11"/>
    </Window.InputBindings>
    <Grid>
        <localControls:WindowControl x:Name="WindowControl" Title="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:MainWindow}, Path=Title, Mode=OneWay}" CornerRadius="{StaticResource WindowCornerRadius}" IsEnabled="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:MainWindow}, Path=ActiveNotification, Mode=OneWay, Converter={StaticResource ObjectNullToBooleanConverter}}" Closed="WindowControl_Closed">
            <localControls:WindowControl.HostedContent>
                <Grid Background="{StaticResource MainWindowBackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <controls:NetAFMarkupTerminal Margin="10" FlowDocumentTheme="{Binding Source={x:Static top:App.Settings}, Path=FontSizeModifier, Mode=OneWay, Converter={StaticResource IntToModifiedFlowDocumentThemeConverter}}" Grid.Row="0">
                        <controls:NetAFMarkupTerminal.Style>
                            <Style TargetType="controls:NetAFMarkupTerminal" BasedOn="{StaticResource DarkMarkupTerminalStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Source={x:Static top:App.Settings}, Path=UseCrtEffect}" Value="True">
                                        <Setter Property="Effect" Value="{StaticResource CrtEffect}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </controls:NetAFMarkupTerminal.Style>
                    </controls:NetAFMarkupTerminal>
                    <layouts:ButtonLayout Style="{StaticResource DarkButtonLayoutStyle}" MaxHeight="250" Margin="10" Visibility="{Binding Source={x:Static top:App.Settings}, Path=ShowCommandButtons, Mode=OneWay, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}" Grid.Row="1" ButtonSelected="ButtonLayout_ButtonSelected"/>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <controls:NetAFPrompt Style="{StaticResource DarkPromptStyle}" Margin="10,0,0,10"  Visibility="{Binding Source={x:Static top:App.Settings}, Path=ShowPrompt, Mode=OneWay, Converter={StaticResource BooleanToVisibilityHiddenConverter}}" Grid.Column="0" KeyPressed="NetAFPrompt_KeyPressed" Loaded="NetAFPrompt_Loaded"/>
                        <Button Command="{StaticResource OpenPersistenceCommand}" Style="{StaticResource IconButtonStyle}" IsEnabled="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:MainWindow}, Path=IsPersistenceAvailable, Mode=OneWay}" Margin="10,0,0,10" Grid.Column="1">
                            <Path Data="{StaticResource SaveIconGeometry}" Style="{StaticResource ButtonIconPathStyle}"/>
                        </Button>
                        <Button Command="{StaticResource OpenSettingsCommand}" Style="{StaticResource IconButtonStyle}" Margin="10,0,0,10" Grid.Column="2">
                            <Path Data="{StaticResource SettingsIconGeometry}" Style="{StaticResource ButtonIconPathStyle}"/>
                        </Button>
                        <Button Command="{StaticResource OpenNoteManagerCommand}" Margin="10,0,10,10" Grid.Column="3" Loaded="NotesButton_Loaded">
                            <Path>
                                <Path.Style>
                                    <Style TargetType="Path" BasedOn="{StaticResource ButtonIconPathStyle}">
                                        <Setter Property="Data" Value="{StaticResource NoteWithIndicatorIconGeometry}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:MainWindow}, Path=PendingNotes.Count}" Value="0">
                                                <Setter Property="Data" Value="{StaticResource NoteIconGeometry}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:MainWindow}, Path=PendingNotes.Count}" Value="0">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Grid>
            </localControls:WindowControl.HostedContent>
        </localControls:WindowControl>
        <Border>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="CornerRadius" Value="{StaticResource WindowCornerRadius}"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Background" Value="Black"/>
                    <Setter Property="IsHitTestVisible" Value="False"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:MainWindow}, Path=ActiveNotification, Mode=OneWay, Converter={StaticResource ObjectNotNullToBooleanConverter}}" Value="True">
                            <Setter Property="IsHitTestVisible" Value="True"/>
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.5" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>
        <ContentControl Content="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:MainWindow}, Path=ActiveNotification, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</Window>
