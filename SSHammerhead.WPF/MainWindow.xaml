<Window x:Class="SSHammerhead.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:NetAF.Targets.WPF.Controls;assembly=NetAF.WPF"
        xmlns:layouts="clr-namespace:NetAF.Targets.WPF.InputLayouts;assembly=NetAF.WPF"
        xmlns:local="clr-namespace:SSHammerhead.WPF"
        xmlns:effects="clr-namespace:LoFiEffects.WPF.Effects;assembly=LoFiEffects.WPF"
        mc:Ignorable="d"
        Title="Trouble Aboard the SS Hammerhead" Height="850" Width="1000">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/NetAF.WPF;component/Targets/WPF/Styles/Dark.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <effects:CrtEffect x:Key="CrtEffect" Intensity="0.5" CurvatureIntensity="0.2" IncludeScanlines="True"/>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Background="{StaticResource MainWindowBackgroundBrush}" >
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <controls:NetAFMarkupTerminal x:Name="Terminal" Margin="10" FlowDocumentTheme="{x:Static local:SSHammerheadThemes.SSHHTheme}" Grid.Row="0">
            <controls:NetAFMarkupTerminal.Style>
                <Style TargetType="controls:NetAFMarkupTerminal" BasedOn="{StaticResource DarkMarkupTerminalStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=UseCrtCheckbox, Path=IsChecked}" Value="True">
                            <Setter Property="Effect" Value="{StaticResource CrtEffect}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </controls:NetAFMarkupTerminal.Style>
        </controls:NetAFMarkupTerminal>
        <Expander Header="Prompt" Style="{StaticResource DarkExpanderStyle}" Padding="6" Margin="10,0,10,10" Grid.Row="1">
            <controls:NetAFPrompt Style="{StaticResource DarkPromptStyle}"/>
        </Expander>
        <Expander Header="Buttons" Style="{StaticResource DarkExpanderStyle}" MaxHeight="210" Padding="4" Margin="10,0,10,10" Grid.Row="2">
            <layouts:ButtonLayout Style="{StaticResource DarkButtonLayoutStyle}"/>
        </Expander>
        <Expander Header="Restore" Style="{StaticResource DarkExpanderStyle}" MaxHeight="250" Padding="4" Margin="10,0,10,10" Grid.Row="3">
            <controls:NetAFFileManager Style="{StaticResource DarkNetAFFileManagerStyle}"/>
        </Expander>
        <Expander Header="Options" Style="{StaticResource DarkExpanderStyle}" Padding="4" Margin="10,0,10,10" Grid.Row="4">
            <CheckBox x:Name="UseCrtCheckbox" Content="Use CRT effect?" Style="{StaticResource CheckboxStyle}" IsChecked="True"/>
        </Expander>
    </Grid>
</Window>
